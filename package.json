{
  "name": "ndi-credential-chain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "test": "bun --filter '*' test",
    "lint": "bun --filter '*' lint",
    "migrate": "bun --filter @ndi/db migrate",
    "contracts:deploy": "bun --filter @ndi/contracts deploy",
    "api:dev": "bun --filter @ndi/api dev",
    "web:dev": "bun --filter @ndi/web dev"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.1.38"
}
